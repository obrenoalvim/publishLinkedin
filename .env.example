# LinkedIn API credentials
# Create an app at https://developer.linkedin.com/
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# Token from auth.js — run `node auth.js` to generate
LINKEDIN_ACCESS_TOKEN=your_access_token_here
LINKEDIN_PERSON_URN=urn:li:person:your_person_id_here

# (Optional) LinkedIn session cookie for post-publish verification
# Find in browser DevTools → Application → Cookies → linkedin.com → li_at
LI_AT=
